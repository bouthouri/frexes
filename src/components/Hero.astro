---
import { TextWall } from "./TextWall";
---
<section class="relative overflow-hidden py-16 sm:py-20 lg:py-24">
  <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <TextWall client:load />
  </div>
  <div class="relative px-4 sm:px-6 max-w-6xl mx-auto flex items-center justify-center min-h-[250px]">
    <div class="bg-background/80 backdrop-blur-sm rounded-xl p-6 sm:p-8 text-center">
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold font-heading tracking-tight">
        Frexes
      </h1>
      <p class="text-lg sm:text-xl text-foreground/70 mt-4 sm:mt-6 max-w-md mx-auto">
        Apps that matters
      </p>
    </div>
  </div>
</section>
