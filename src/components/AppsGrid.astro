---
import { apps } from "../data/apps";
import { AppCard } from "./AppCard";
import { LazyMotionProvider } from "./motion/LazyMotionProvider";
---

<section id="apps" class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8">
  <h2 class="mb-10 text-center font-heading text-2xl font-bold sm:text-3xl">
    What I'm Building
  </h2>
  <LazyMotionProvider client:visible>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {apps.map((app) => <AppCard app={app} />)}
    </div>
  </LazyMotionProvider>
</section>
